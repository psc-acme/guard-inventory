{
    "name": "psc-acme/guard-inventory",
    "description": "Package guard-inventory for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\GuardInventory\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "monolog/monolog": "^3.2.0",
        "predis/predis": "^2.0",
        "symfony/messenger": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}